NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lia_core
HTTP_INTERNAL_API_KEY=replace-with-a-long-random-internal-token
HTTP_GATEWAY_API_KEY=replace-with-a-long-random-gateway-token
LOG_LEVEL=info
MCP_PORT=3100
MCP_API_KEY=replace-with-a-long-random-mcp-token
MCP_ALLOWED_HOSTS=localhost,127.0.0.1
MCP_ENABLE_JSON_RESPONSE=true
JWT_SECRET=replace-with-a-long-random-jwt-secret
